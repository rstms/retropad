#!/bin/sh

if [ -n "$(git status --porcelain)" ]; then
    echo >&2 git status is dirty
    exit 1
fi

VERSION=$(cat VERSION)
GITHUB_ORG=$(git remote -v | awk -F'[:/ ]' '/fetch/{print $2}')
GITHUB_REPO=$(git remote -v | awk -F'[:/ ]' '/fetch/{print $3}')
INSTALLER=${GITHUB_REPO}-v${VERSION}-win32.exe

if [ ! -f $INSTALLER ]; then
    echo >&2 Not found: $INSTALLER
    exit 1
fi

output=$(curl -X POST -H "Authorization: token $GITHUB_TOKEN" \
    -H "Content-Type: application/json" \
    -d "{
    \"tag_name\": \"v${VERSION}\",
    \"target_commitish\": \"main\",
    \"name\": \"Release v${VERSION}\", 
    \"body\": \"Release v${VERSION}\",
    \"draft\": false,
    \"prerelease\": false
    }" https://api.github.com/repos/${GITHUB_ORG}/${GITHUB_REPO}/releases)

RELEASE_ID=$(echo $output | jq .id)
FILENAME=$(basename $INSTALLER)
FILETYPE=$(file --mime-type -b $INSTALLER)
UPLOAD_URL="https://uploads.github.com/repos/${GITHUB_ORG}/${GITHUB_REPO}/releases/${RELEASE_ID}/assets?name=$FILENAME"

curl -s -X POST -H "Authorization: token $GITHUB_TOKEN" \
    -H "Content-Type: $FILETYPE" \
    --data-binary @$INSTALLER \
    $UPLOAD_URL | jq .

